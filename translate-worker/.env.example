HOST=0.0.0.0
PORT=8082

# NLLB-200-distilled-600M + CTranslate2 (repo HF hoặc đường dẫn thư mục)
CT2_MODEL=JustFrederik/nllb-200-distilled-600M-ct2
NLLB_TOKENIZER=facebook/nllb-200-distilled-600M

# Mã ngôn ngữ NLLB: eng_Latn (Anh), vie_Latn (Việt)
NLLB_SOURCE_LANG=eng_Latn
NLLB_TARGET_LANG=vie_Latn

# Thiết bị: cpu, cuda, auto
CT2_DEVICE=auto
# Kiểu tính toán: default, float16, int8, int8_float16
CT2_COMPUTE_TYPE=default

# Tham số dịch — ưu trong .env
CT2_BEAM_SIZE=4
CT2_LENGTH_PENALTY=1.0
CT2_PATIENCE=1.0
CT2_MAX_DECODING_LENGTH=256
CT2_MAX_INPUT_LENGTH=1024
CT2_REPETITION_PENALTY=1.0
CT2_NO_REPEAT_NGRAM_SIZE=0

# Luồng CPU (0 = mặc định)
CT2_INTRA_THREADS=0
CT2_INTER_THREADS=1
